{
    "openapi": "3.0.0",
    "info": {
        "title": "Forge Progress API",
        "version": "1.0.0",
        "description": "Documentação completa do sistema de gestão de treinos."
    },
    "paths": {
        "/usuario/cadastro": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Cria um novo usuário",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Usuario"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuário criado com sucesso"
                    },
                    "400": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
        "/usuario/login": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Realiza o login e retorna o token JWT",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "kaio@teste.com"
                                    },
                                    "senha": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login realizado"
                    },
                    "401": {
                        "description": "Credenciais inválidas"
                    }
                }
            }
        },
        "/treino/listar": {
            "get": {
                "tags": [
                    "Treinos"
                ],
                "summary": "Lista todos os treinos do usuário logado",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sucesso"
                    }
                }
            },
            "post": {
                "tags": [
                    "Treinos"
                ],
                "summary": "Adiciona um novo treino",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Treino"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Treino criado"
                    }
                }
            }
        },
        "/treinos/atualizar{id}": {
            "put": {
                "tags": [
                    "Treinos"
                ],
                "summary": "Atualiza um treino existente",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Treino"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Treino atualizado"
                    }
                }
            },
            "/delete/deletar": {
                "tags": [
                    "Treinos"
                ],
                "summary": "Remove um treino",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Treino removido"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "Usuario": {
                "type": "object",
                "properties": {
                    "nome": {
                        "type": "string",
                        "example": "Kaio"
                    },
                    "email": {
                        "type": "string",
                        "example": "kaio@teste.com"
                    },
                    "senha": {
                        "type": "string",
                        "example": "123456"
                    },
                    "idade": {
                        "type": "number",
                        "example": 16
                    },
                    "peso": {
                        "type": "number",
                        "example": 75.5
                    },
                    "altura": {
                        "type": "number",
                        "example": 1.75
                    }
                }
            },
            "Treino": {
                "type": "object",
                "properties": {
                    "exercicio": {
                        "type": "string",
                        "example": "Supino Reto"
                    },
                    "carga": {
                        "type": "number",
                        "example": 80
                    },
                    "repeticoes": {
                        "type": "number",
                        "example": 12
                    }
                }
            }
        }
    }
}